{
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "lint": "biome lint .",
    "format": "biome format --write . && pnpm run sort:classes",
    "check": "biome check .",
    "check:fix": "biome check --write . && pnpm run sort:classes",
    "sort:classes": "biome lint . --write --unsafe --only=nursery/useSortedClasses"
  },
