{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "trailingComma": "all",
  "ignorePatterns": ["src/routeTree.gen.ts", "src/contracts/generated/**"],
  "sortImports": {
    "internalPattern": ["#/*", "@/*"]
  },
  "sortTailwindcss": {
    "functions": ["cn", "clsx", "cva"]
  }
}
